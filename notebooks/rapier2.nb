Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"Existing", " ", "floor", " ", "setup"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"floorId", "=", 
     RowBox[{"RapierAddRigidBody", "[", 
      RowBox[{"worldId", ",", 
       RowBox[{"{", 
        RowBox[{"0.0", ",", "0.0", ",", 
         RowBox[{"-", "1.0"}]}], "}"}], ",", "\"\<Fixed\>\""}], "]"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"RapierAddColliderCuboid", "[", 
     RowBox[{"worldId", ",", "floorId", ",", 
      RowBox[{"{", 
       RowBox[{"10.0", ",", "10.0", ",", "1.0"}], "}"}], ",", "1.0"}], "]"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Set", " ", "the", " ", "desired", " ", "wall", " ", "height"}], 
    "*)"}], 
   RowBox[{
    RowBox[{"wallHeight", "=", "5.0"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"wallZCenter", "=", 
     RowBox[{"wallHeight", "/", "2.0"}]}], ";"}], " ", 
   RowBox[{"(*", 
    RowBox[{"The", " ", "center", " ", "position", " ", "in", " ", "Z"}], 
    "*)"}], "\n", 
   RowBox[{
    RowBox[{"wallZExtent", "=", 
     RowBox[{"wallHeight", "/", "2.0"}]}], ";"}], " ", 
