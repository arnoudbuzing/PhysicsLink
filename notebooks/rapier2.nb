         "\[IndentingNewLine]", 
        RowBox[{"RapierAddColliderCuboid", "[", 
         RowBox[{"worldId", ",", "wallId", ",", 
          RowBox[{"config", "[", 
           RowBox[{"[", "2", "]"}], "]"}], ",", "1.0"}], "]"}]}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"config", ",", "wallConfigs"}], "}"}]}], "]"}], 
