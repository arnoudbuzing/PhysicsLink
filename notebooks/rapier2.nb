         RowBox[{"{", 
          RowBox[{"0.5", ",", "10.0", ",", "wallZExtent"}], "}"}]}], "}"}], ",", 
       RowBox[{"(*", 
        RowBox[{"X", "+"}], "*)"}], 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "10.5"}], ",", "0.0", ",", "wallZCenter"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"0.5", ",", "10.0", ",", "wallZExtent"}], "}"}]}], "}"}], ",", 
       RowBox[{"(*", 
        RowBox[{"X", "-"}], "*)"}], 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0.0", ",", "10.5", ",", "wallZCenter"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"11.0", ",", "0.5", ",", "wallZExtent"}], "}"}]}], "}"}], ",", 
       RowBox[{"(*", 
        RowBox[{"Y", "+"}], "*)"}], 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"0.0", ",", 
           RowBox[{"-", "10.5"}], ",", "wallZCenter"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"11.0", ",", "0.5", ",", "wallZExtent"}], "}"}]}], "}"}]}], 
      "  ", 
      RowBox[{"(*", 
       RowBox[{"Y", "-"}], "*)"}], "}"}]}], ";"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "Add", " ", "each", " ", "wall", " ", "to", " ", "the", " ", "world"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Do", "[", 
    RowBox[{
     RowBox[{"Module", "[", 
