Cell["\<\
Besides balls and cuboids as shapes, you can use cylinders, cones, capsules, \
and the convex hull of a set of points. Here is an example of a dodecahedron \
rolling over an inclined plane (two convex hull meshes).\
\>", "Text",
 CellChangeTimes->{{3.985869929554079*^9, 
  3.9858700657570753`*^9}},ExpressionUUID->"6bffc58c-cfda-4de1-a756-\
c2dd63eea271"],

Cell["Create the model:", "CodeText",
 CellChangeTimes->{{3.985870071724976*^9, 
  3.985870073679044*^9}},ExpressionUUID->"55702b5e-5705-437a-9ea0-\
7d5e79cf1708"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"dodecahedron", "=", 
   RowBox[{"Translate", "[", 
    RowBox[{
     RowBox[{"ConvexHullMesh", "[", 
      RowBox[{"N", "[", 
       RowBox[{"PolyhedronData", "[", 
        RowBox[{"\"\<Dodecahedron\>\"", ",", "\"\<Points\>\""}], "]"}], "]"}],
       "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"3", ",", "0", ",", "5"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"model", "=", 
  RowBox[{"CreatePhysicsModel", "[", 
   RowBox[{
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"DynamicBody", "[", 
       RowBox[{"{", 
        RowBox[{"StandardOrange", ",", 
         RowBox[{"HatchShading", "[", "]"}], ",", "dodecahedron"}], "}"}], 
       "]"}], ",", 
      RowBox[{"PhysicsBoundaryBox", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "5"}], ",", 
           RowBox[{"-", "5"}], ",", "0"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"5", ",", "5", ",", "7"}], "}"}]}], "}"}], "]"}], ",", 
      RowBox[{"FixedBody", "[", 
       RowBox[{"{", 
        RowBox[{"Gray", ",", 
         RowBox[{"HatchShading", "[", "]"}], ",", 
         RowBox[{"ConvexHullMesh", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "5"}], ",", 
              RowBox[{"-", "5"}], ",", "0"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "5"}], ",", "5", ",", "0"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"5", ",", "5", ",", "0"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"5", ",", 
              RowBox[{"-", "5"}], ",", "0"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "5"}], ",", 
              RowBox[{"-", "5"}], ",", "1"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"-", "5"}], ",", "5", ",", "1"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"5", ",", "5", ",", "3"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"5", ",", 
              RowBox[{"-", "5"}], ",", "3"}], "}"}]}], "}"}], "]"}]}], "}"}], 
       "]"}]}], "}"}], ",", 
    InterpretationBox[
     DynamicModuleBox[{Typeset`open = False}, 
      TemplateBox[{"Expression", 
        RowBox[{
          DynamicBox[
           FEPrivate`FrontEndResource["FEBitmaps", "IconizeEllipsis"]], 
          "\[Rule]", 
          DynamicBox[
           FEPrivate`FrontEndResource["FEBitmaps", "IconizeEllipsis"]]}], 
        GridBox[{{
           RowBox[{
             TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
             TagBox["Rule", "IconizedItem"]}]}, {
           RowBox[{
             TagBox["\"Byte count: \"", "IconizedLabel"], "\[InvisibleSpace]", 
             TagBox["928", "IconizedItem"]}]}}, 
         GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
         "Column", 
         GridBoxItemSize -> {
          "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
        Dynamic[Typeset`open]},
       "IconizedObject"]],
     "Graphics3DOptions" -> {
      ViewPoint -> Front, PlotRange -> 1.01 {{-5, 5}, {-5, 5}, {0, 7}}, 
       Background -> Black, Axes -> False, Boxed -> False, ImageSize -> Large},
     SelectWithContents->True,
     Selectable->False]}], "]"}]}]}], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.9852044622730217`*^9, 3.9852044899992027`*^9}, {
  3.9858088038017073`*^9, 3.9858088316222277`*^9}},
 CellLabel->"In[6]:=",
 CellID->347352806,ExpressionUUID->"bda16975-e318-42d8-876f-64f486db6287"],

