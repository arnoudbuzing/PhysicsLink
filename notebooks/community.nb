Cell["\<\
Physical models contain fixed and dynamic bodies. Fixed bodies are typically \
used for floors and walls. Dynamic bodies move in space and are subject to \
gravitational forces. Dynamic bodies interact with other bodies and bounce \
off each other. A physical model can also contain a physical boundary box \
which acts as in convenient invisible wall in case you want to constrain your \
dynamic bodies to a scene.\
\>", "Text",
 CellChangeTimes->{{3.985867270455421*^9, 
  3.985867523541452*^9}},ExpressionUUID->"678dcfdb-8e9e-4f16-a584-\
7c27b99c2a5d"],

Cell["Create the model:", "CodeText",
 CellChangeTimes->{{3.9858672627665*^9, 
  3.985867265220724*^9}},ExpressionUUID->"168f5088-7f56-45b8-8f99-\
db379c851dd7"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"model", "=", 
  RowBox[{"CreatePhysicsModel", "[", 
   RowBox[{
    RowBox[{"{", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"PhysicsBoundaryBox", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "4"}], ",", 
            RowBox[{"-", "4"}], ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"4", ",", "4", ",", "6"}], "}"}]}], "}"}], ",", 
        RowBox[{"\"\<Thickness\>\"", "->", "1"}]}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"FixedBody", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"HatchShading", "[", 
          RowBox[{".6", ",", "Blue"}], "]"}], ",", 
         RowBox[{"Cuboid", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "4"}], ",", 
             RowBox[{"-", "4"}], ",", 
             RowBox[{"-", "1"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"4", ",", "4", ",", "0"}], "}"}]}], "]"}]}], "}"}], "]"}],
       ",", "\[IndentingNewLine]", 
      RowBox[{"DynamicBody", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"MaterialShading", "[", "\"\<Gold\>\"", "]"}], ",", 
         RowBox[{"Sphere", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"0", ",", "0", ",", "5"}], "}"}], ",", "0.6"}], "]"}]}], 
        "}"}], "]"}]}], "}"}], ",", "\[IndentingNewLine]", 
    InterpretationBox[
     DynamicModuleBox[{Typeset`open = False}, 
      TemplateBox[{"Expression", "SequenceIcon", 
        GridBox[{{
           RowBox[{
             TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
             TagBox["Sequence", "IconizedItem"]}]}, {
           RowBox[{
             TagBox["\"Length: \"", "IconizedLabel"], "\[InvisibleSpace]", 
             TagBox["2", "IconizedItem"]}]}, {
           RowBox[{
             TagBox["\"Byte count: \"", "IconizedLabel"], "\[InvisibleSpace]", 
             TagBox["720", "IconizedItem"]}]}}, 
         GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
         "Column", 
         GridBoxItemSize -> {
          "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
        Dynamic[Typeset`open]},
       "IconizedObject"]],
     Sequence[
     "Gravity" -> {0, 0, -9.81}, 
      "Graphics3DOptions" -> {
       Background -> Black, Axes -> False, Boxed -> False, ViewPoint -> Front,
         ImageSize -> Large}],
     SelectWithContents->True,
     Selectable->False]}], "]"}]}]], "Input",
