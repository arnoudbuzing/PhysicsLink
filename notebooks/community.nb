Cell["\<\
Models can be evolved over time with PhysicsModelEvolve. This function \
returns a list of PhysicsModelObject(s) which contain the complete state over \
time.\
\>", "Text",
 CellChangeTimes->{{3.985867690401997*^9, 
  3.985867759640533*^9}},ExpressionUUID->"79d0bc57-7e0b-4cb7-bcb6-\
0f5fc6cf7088"],

Cell["Generate 300 frames with a 1/60 second time step:", "CodeText",
 CellChangeTimes->{{3.985867674302464*^9, 
  3.98586768561017*^9}},ExpressionUUID->"34f60d7f-6ff7-4e94-ac28-\
d0ceb3aaf62d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"frames", "=", 
   RowBox[{"PhysicsModelEvolve", "[", 
    RowBox[{"model", ",", "300", ",", 
     RowBox[{"1", "/", "60"}]}], "]"}]}], ";"}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.9850084869451513`*^9, 3.9850084924581947`*^9}},
 CellLabel->"In[9]:=",
 CellID->1775089723,ExpressionUUID->"18ab2e3a-5734-4f64-be0b-9b146b0096b8"],

Cell["\<\
These frames can then be used with, for example, PhysicsModelVideo to create \
a complete animation of the model as it evolves over time.\
\>", "Text",
 CellChangeTimes->{{3.985867788756315*^9, 
  3.985867863519339*^9}},ExpressionUUID->"375a467d-d74a-4929-91ea-\
31fe59a30a71"],

Cell["Generate a video from the list of frames:", "CodeText",
 CellChangeTimes->{{3.985867773446033*^9, 
  3.985867778941903*^9}},ExpressionUUID->"ab0fad6c-597a-4b0b-bd87-\
f2f17dbde519"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"PhysicsModelVideo", "[", 
  RowBox[{"frames", ",", 
   RowBox[{"PlotRange", "\[Rule]", 
    RowBox[{"1.01`", " ", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"-", "1"}], ",", "6"}], "}"}]}], "}"}]}]}]}], "]"}]], "Input",\

 TaggingRules->{},
 CellChangeTimes->{{3.985008537201736*^9, 3.9850085416906557`*^9}, {
   3.985008594433008*^9, 3.985008614377039*^9}, 3.985008710555266*^9, {
