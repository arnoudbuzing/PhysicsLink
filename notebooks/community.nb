Cell["\<\
You can of course use many many more balls. Here is another over 100 balls \
bouncing of one larger ball. I am using the boundary box to constrain the \
balls from falling down endlessly.\
\>", "Text",
 CellChangeTimes->{{3.985869380954649*^9, 3.9858694496804028`*^9}, {
  3.9858698156676407`*^9, 
  3.9858698476548853`*^9}},ExpressionUUID->"41e222ec-c256-4389-bd99-\
c4ad8a877fea"],

Cell["Create the model:", "CodeText",
 CellChangeTimes->{{3.98586985153216*^9, 
  3.985869855280388*^9}},ExpressionUUID->"f55790f5-2b4a-4c0f-b5af-\
ccaf789a0b65"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"model", "=", 
  RowBox[{"CreatePhysicsModel", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"PhysicsBoundaryBox", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "5"}], ",", 
           RowBox[{"-", "5"}], ",", 
           RowBox[{"-", "10"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"5", ",", "5", ",", "16"}], "}"}]}], "}"}], "]"}], ",", 
      RowBox[{"FixedBody", "[", 
       RowBox[{"{", 
        RowBox[{"Sphere", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", "0", ",", 
            RowBox[{"-", "6"}]}], "}"}], ",", "4"}], "]"}], "}"}], "]"}], ",", 
      RowBox[{"Flatten", "@", 
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"DynamicBody", "[", 
          RowBox[{"{", 
           RowBox[{"Sphere", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"{", 
               RowBox[{"i", ",", "j", ",", "k"}], "}"}], "+", 
              RowBox[{"RandomReal", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"-", "0.01"}], ",", "0.01"}], "}"}], ",", "3"}], 
               "]"}]}], ",", "0.25"}], "]"}], "}"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"i", ",", 
           RowBox[{"-", "3"}], ",", "3"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"j", ",", 
           RowBox[{"-", "3"}], ",", "3"}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "0", ",", "14"}], "}"}]}], "]"}]}]}], "}"}], ",", 
    
    InterpretationBox[
     DynamicModuleBox[{Typeset`open = False}, 
      TemplateBox[{"Expression", 
        RowBox[{
          DynamicBox[
           FEPrivate`FrontEndResource["FEBitmaps", "IconizeEllipsis"]], 
          "\[Rule]", 
          DynamicBox[
           FEPrivate`FrontEndResource["FEBitmaps", "IconizeEllipsis"]]}], 
        GridBox[{{
           RowBox[{
             TagBox["\"Head: \"", "IconizedLabel"], "\[InvisibleSpace]", 
             TagBox["Rule", "IconizedItem"]}]}, {
           RowBox[{
             TagBox["\"Byte count: \"", "IconizedLabel"], "\[InvisibleSpace]", 
             TagBox["928", "IconizedItem"]}]}}, 
         GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
         "Column", 
         GridBoxItemSize -> {
          "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
        Dynamic[Typeset`open]},
       "IconizedObject"]],
     "Graphics3DOptions" -> {
      PlotRange -> 1.05 {{-7, 7}, {-7, 7}, {-10, 10}}, Background -> Black, 
       Axes -> False, Boxed -> False, ViewPoint -> Front, ImageSize -> Large},
     
     SelectWithContents->True,
     Selectable->False]}], "]"}]}]], "Input",
