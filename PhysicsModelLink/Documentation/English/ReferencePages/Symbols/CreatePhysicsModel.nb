Cell["\<\
Create a new model with a fixed floor and a dynamic cylinder:\
\>", "ExampleText",
 CellChangeTimes->{{3.985011850371975*^9, 3.985011868028563*^9}},
 CellID->2067390575,ExpressionUUID->"39b890ae-5956-4f03-add6-57ea424a3a4e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"model", "=", 
  RowBox[{"CreatePhysicsModel", "[", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"FixedBody", "[", 
      RowBox[{"{", 
       RowBox[{"Cuboid", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "5"}], ",", 
           RowBox[{"-", "5"}], ",", 
           RowBox[{"-", "1"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"5", ",", "5", ",", "0"}], "}"}]}], "]"}], "}"}], "]"}], ",",
      "\[IndentingNewLine]", 
     RowBox[{"DynamicBody", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Cylinder", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", "0", ",", "4"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"0", ",", "0", ",", "5"}], "}"}]}], "}"}], ",", "0.5"}], 
         "]"}], "}"}], ",", 
       RowBox[{"\"\<Orientation\>\"", "->", 
        RowBox[{"RotationMatrix", "[", 
         RowBox[{
          RowBox[{"30", " ", "Degree"}], ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", "1", ",", "0"}], "}"}]}], "]"}]}]}], "]"}]}], 
    "}"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.985011554217761*^9, 3.985011619959457*^9}, 
   3.9850117036479683`*^9},
 CellLabel->"In[12]:=",
 CellID->925995397,ExpressionUUID->"76709f94-6c27-4e69-8fb7-96abd36a375c"],

