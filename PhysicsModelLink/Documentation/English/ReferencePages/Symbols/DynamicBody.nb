Cell["\<\
Create a model with three spheres with different restitution values \
(\"bounciness\"):\
\>", "ExampleText",
 CellChangeTimes->{{3.985012186211026*^9, 3.985012220328026*^9}},
 CellID->307349383,ExpressionUUID->"fccd5618-f0a9-494f-86bc-14836fa47082"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"model", "=", 
  RowBox[{"CreatePhysicsModel", "[", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"FixedBody", "[", 
      RowBox[{"{", 
       RowBox[{"Cuboid", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "5"}], ",", 
           RowBox[{"-", "5"}], ",", 
           RowBox[{"-", "1"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"5", ",", "5", ",", "0"}], "}"}]}], "]"}], "}"}], "]"}], ",",
      "\[IndentingNewLine]", 
     RowBox[{"DynamicBody", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Sphere", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "2.5"}], ",", 
            RowBox[{"-", "2.5"}], ",", "4"}], "}"}], ",", "0.5"}], "]"}], 
        "}"}], ",", 
       RowBox[{"\"\<Restitution\>\"", "->", "0.33"}]}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"DynamicBody", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Sphere", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", "0", ",", "4"}], "}"}], ",", "0.5"}], "]"}], 
        "}"}], ",", 
       RowBox[{"\"\<Restitution\>\"", "->", "0.67"}]}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"DynamicBody", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Sphere", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"2.5", ",", "2.5", ",", "4"}], "}"}], ",", "0.5"}], "]"}], 
        "}"}], ",", 
       RowBox[{"\"\<Restitution\>\"", "->", "1.0"}]}], "]"}]}], 
    "\[IndentingNewLine]", "}"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.985011554217761*^9, 3.985011619959457*^9}, 
   3.9850117036479683`*^9, {3.9850119664921303`*^9, 3.98501208639983*^9}, {
   3.985012116619182*^9, 3.9850121430495577`*^9}, {3.9850122906507473`*^9, 
   3.985012294766464*^9}},
