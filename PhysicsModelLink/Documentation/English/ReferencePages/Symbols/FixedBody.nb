Cell[TextData[{
 Cell["   ", "ModInfo",ExpressionUUID->"e3256e4c-3fbe-4aaf-9011-39ecbcf68781"],
 Cell[BoxData[
  RowBox[{
   ButtonBox["FixedBody",
    BaseStyle->"Link",
    ButtonData->"paclet:ArnoudBuzingPhysicsModelLink/ref/FixedBody"], "[", 
   RowBox[{
    StyleBox["primitive", "TI"], ",", 
    StyleBox["opts", "TI"]}], "]"}]], "InlineFormula",ExpressionUUID->
  "10b64986-0c37-46fb-ae87-70ed0ec1f2cc"],
 "\[LineSeparator]wraps a graphics ",
 Cell[BoxData[
  StyleBox["primitive", "TI"]], "InlineFormula",ExpressionUUID->
  "4664aa01-2ac2-4cb5-9e58-ebc512724dc7"],
 " as a fixed (immovable) rigid body."
}], "Usage",
 CellChangeTimes->{{3.9850095762270737`*^9, 3.9850095762315817`*^9}},
