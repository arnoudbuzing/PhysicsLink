     "a8b6639b-954a-4a7a-a564-c337daef43e8"]},
   {Cell["      ", "ModInfo",ExpressionUUID->
     "3a329fc0-e256-4284-b9ce-81ee10ea8f68"], "\"\<Orientiation\>\"", 
    RowBox[{"IdentityMatrix", "[", "3", "]"}], Cell[
