   {Cell["      ", "ModInfo",ExpressionUUID->
     "1796ac66-3110-451a-9ad4-ae5a4fa5766a"], "\"\<Restitution\>\"", "0.5", 
    Cell["bounciness (0 is no bounce, 1 is fully elastic)", "TableText",
