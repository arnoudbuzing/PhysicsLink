Cell["\<\
Create a model with three spheres with different restitution values \
(\"bounciness\"):\
\>", "ExampleText",
 CellID->307349383,ExpressionUUID->"1b6d2c1e-355c-41f9-9d0c-3a64e7ab0f1d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"model", "=", 
  RowBox[{"CreatePhysicsModel", "[", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"FixedBody", "[", 
      RowBox[{"{", 
       RowBox[{"Cuboid", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "5"}], ",", 
           RowBox[{"-", "5"}], ",", 
           RowBox[{"-", "1"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"5", ",", "5", ",", "0"}], "}"}]}], "]"}], "}"}], "]"}], ",",
      "\[IndentingNewLine]", 
     RowBox[{"DynamicBody", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Sphere", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "2.5"}], ",", 
            RowBox[{"-", "2.5"}], ",", "4"}], "}"}], ",", "0.5"}], "]"}], 
        "}"}], ",", 
       RowBox[{"\"\<Restitution\>\"", "->", "0.33"}]}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"DynamicBody", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Sphere", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", "0", ",", "4"}], "}"}], ",", "0.5"}], "]"}], 
        "}"}], ",", 
       RowBox[{"\"\<Restitution\>\"", "->", "0.67"}]}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"DynamicBody", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Sphere", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"2.5", ",", "2.5", ",", "4"}], "}"}], ",", "0.5"}], "]"}], 
        "}"}], ",", 
       RowBox[{"\"\<Restitution\>\"", "->", "1.0"}]}], "]"}]}], 
    "\[IndentingNewLine]", "}"}], "]"}]}]], "Input",
