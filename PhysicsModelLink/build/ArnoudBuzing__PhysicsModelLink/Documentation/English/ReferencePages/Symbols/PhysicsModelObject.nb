Cell["Create a collection of \"dominoes\":", "ExampleText",
 CellID->1197853575,ExpressionUUID->"baeafc39-9454-47b1-813e-2e8929ad5c9e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"dominoes", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"DynamicBody", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"MaterialShading", "[", "\"\<Copper\>\"", "]"}], ",", 
        RowBox[{"Cuboid", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"x", "-", "0.08"}], ",", 
            RowBox[{"-", "0.3"}], ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"x", "+", "0.08"}], ",", "0.3", ",", "0.8"}], "}"}]}], 
         "]"}]}], "}"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "3"}], ",", "3", ",", "0.6"}], "}"}]}], "]"}]}], 
  ";"}]], "Input",
 CellProlog:>Needs["ArnoudBuzing`PhysicsModelLink`"],
 CellLabel->"In[1]:=",
 CellID->1304413954,ExpressionUUID->"b56eef60-8f34-495d-9a05-14d3b7648d0a"],

Cell["Create a ball that will push over the dominoes:", "ExampleText",
 CellID->923275861,ExpressionUUID->"29f0299b-a9c0-4826-af69-977ca54a4d1e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ball", "=", 
   RowBox[{"DynamicBody", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"MaterialShading", "[", "\"\<Gold\>\"", "]"}], ",", 
       RowBox[{"Sphere", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "3.8"}], ",", "0", ",", "0.4"}], "}"}], ",", "0.35"}],
         "]"}]}], "}"}], ",", 
     RowBox[{"\"\<Density\>\"", "->", "5.0"}], ",", 
     RowBox[{"\"\<Velocity\>\"", "->", 
      RowBox[{"{", 
       RowBox[{"3", ",", "0", ",", "0"}], "}"}]}]}], "]"}]}], ";"}]], "Input",\

 CellProlog:>Needs["ArnoudBuzing`PhysicsModelLink`"],
 CellLabel->"In[2]:=",
 CellID->1772256302,ExpressionUUID->"38c256f8-63af-48a1-a099-2ee267f35277"],

Cell["Create the model from the ball and dominoes:", "ExampleText",
 CellID->1421090451,ExpressionUUID->"03a38700-36e9-422b-b94e-90a34f940231"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"model", "=", 
  RowBox[{"CreatePhysicsModel", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"PhysicsBoundaryBox", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "4"}], ",", 
            RowBox[{"-", "4"}], ",", "0"}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"4", ",", "4", ",", "6"}], "}"}]}], "}"}], ",", 
        RowBox[{"\"\<Thickness\>\"", "->", "1"}]}], "]"}], ",", 
      RowBox[{"FixedBody", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"HatchShading", "[", 
          RowBox[{".6", ",", "Gray"}], "]"}], ",", 
         RowBox[{"Cuboid", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{"-", "4"}], ",", 
             RowBox[{"-", "4"}], ",", 
             RowBox[{"-", "1"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"4", ",", "4", ",", "0"}], "}"}]}], "]"}]}], "}"}], "]"}],
       ",", "dominoes", ",", "ball"}], "}"}], ",", 
    RowBox[{"\"\<Gravity\>\"", "->", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", 
       RowBox[{"-", "9.81"}]}], "}"}]}], ",", 
    RowBox[{"\"\<Graphics3DOptions\>\"", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Background", "->", "Black"}], ",", 
       RowBox[{"Axes", "->", "False"}], ",", 
       RowBox[{"Boxed", "->", "False"}], ",", 
       RowBox[{"ViewPoint", "->", "Front"}], ",", 
       RowBox[{"ImageSize", "->", "Large"}]}], "}"}]}]}], "]"}]}]], "Input",
 CellProlog:>Needs["ArnoudBuzing`PhysicsModelLink`"],
 CellLabel->"In[3]:=",
 CellID->364826354,ExpressionUUID->"099e2a7a-8e90-4cfc-ae12-5823e232d493"],

