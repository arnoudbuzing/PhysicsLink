Cell["\<\
Create a model with three spheres with different restitution values \
(\"bounciness\") and a fixed floor\
\>", "ExampleText",
 CellID->307349383,ExpressionUUID->"de76dab5-62c2-4609-945e-75303d64dbda"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"model", "=", 
  RowBox[{"CreatePhysicsModel", "[", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"FixedBody", "[", 
      RowBox[{"{", 
       RowBox[{"Cuboid", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "5"}], ",", 
           RowBox[{"-", "5"}], ",", 
           RowBox[{"-", "1"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"5", ",", "5", ",", "0"}], "}"}]}], "]"}], "}"}], "]"}], ",",
      "\[IndentingNewLine]", 
     RowBox[{"DynamicBody", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Sphere", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "2.5"}], ",", 
            RowBox[{"-", "2.5"}], ",", "4"}], "}"}], ",", "0.5"}], "]"}], 
        "}"}], ",", 
       RowBox[{"\"\<Restitution\>\"", "->", "0.33"}]}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"DynamicBody", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Sphere", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", "0", ",", "4"}], "}"}], ",", "0.5"}], "]"}], 
        "}"}], ",", 
       RowBox[{"\"\<Restitution\>\"", "->", "0.67"}]}], "]"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"DynamicBody", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Sphere", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"2.5", ",", "2.5", ",", "4"}], "}"}], ",", "0.5"}], "]"}], 
        "}"}], ",", 
       RowBox[{"\"\<Restitution\>\"", "->", "1.0"}]}], "]"}]}], 
    "\[IndentingNewLine]", "}"}], "]"}]}]], "Input",
 CellProlog:>Needs["ArnoudBuzing`PhysicsModelLink`"],
 CellLabel->"In[1]:=",
 CellID->925995397,ExpressionUUID->"2c5d912b-386a-4c02-8ca8-f7496e7d9c93"],

