Cell["\<\
Create a new model with a fixed floor and a dynamic cylinder:\
\>", "ExampleText",
 CellID->2067390575,ExpressionUUID->"a6b053c5-e9a6-4a08-b56f-27425281ed9b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"model", "=", 
  RowBox[{"CreatePhysicsModel", "[", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"FixedBody", "[", 
      RowBox[{"{", 
       RowBox[{"Cuboid", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"-", "5"}], ",", 
           RowBox[{"-", "5"}], ",", 
           RowBox[{"-", "1"}]}], "}"}], ",", 
         RowBox[{"{", 
          RowBox[{"5", ",", "5", ",", "0"}], "}"}]}], "]"}], "}"}], "]"}], ",",
      "\[IndentingNewLine]", 
     RowBox[{"DynamicBody", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Cylinder", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"0", ",", "0", ",", "4"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"0", ",", "0", ",", "5"}], "}"}]}], "}"}], ",", "0.5"}], 
         "]"}], "}"}], ",", 
       RowBox[{"\"\<Orientation\>\"", "->", 
        RowBox[{"RotationMatrix", "[", 
         RowBox[{
          RowBox[{"30", " ", "Degree"}], ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", "1", ",", "0"}], "}"}]}], "]"}]}]}], "]"}]}], 
    "}"}], "]"}]}]], "Input",
 CellProlog:>Needs["ArnoudBuzing`PhysicsModelLink`"],
 CellLabel->"In[1]:=",
 CellID->925995397,ExpressionUUID->"e682cbad-9f92-4468-8e9d-d2e415628502"],

